# Configuration de l'application PharmaBenin
# Copier ce fichier en .env et remplir les valeurs

# Base de données
DB_URL=jdbc:postgresql://localhost:5432/pharmabenin
DB_USERNAME=postgres
DB_PASSWORD=votre_mot_de_passe

# Google Maps API
GOOGLE_MAPS_API_KEY=votre_cle_api_google_maps

# Sécurité
JWT_SECRET=votre_secret_jwt_tres_long_et_securise
ADMIN_DEFAULT_PASSWORD=admin123

# Email (pour notifications futures)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre_email@gmail.com
MAIL_PASSWORD=votre_mot_de_passe_email

# SMS (pour notifications futures)
SMS_API_KEY=votre_cle_api_sms
SMS_SENDER_ID=PharmaBenin

# Application
APP_URL=http://localhost:8080
APP_ENV=development

# Logs
LOG_LEVEL=INFO
